<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:id="@+id/tvEditCommunity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Edit"
                    android:textColor="@color/green_primary"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Foto & nama komunitas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgCommunityPhoto"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_default_avatar" />

                <TextView
                    android:id="@+id/tvCommunityName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="Futsal Depok Squad" />

                <TextView
                    android:id="@+id/tvCategoryAndMembers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Futsal · 12 anggota" />
            </LinearLayout>

            <!-- Deskripsi -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                tools:text="Komunitas futsal santai setiap weekend di Depok" />

            <!-- Tombol Join Komunitas (tampil kalau user BELUM join) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinCommunity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="@color/green_primary"
                android:text="Join Komunitas"
                android:textAllCaps="false"
                app:cornerRadius="26dp"
                android:visibility="gone" />

            <!-- Tombol Join WA (tampil kalau user SUDAH join) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#25D366"
                android:text="Join Grup WhatsApp"
                android:textAllCaps="false"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_whatsapp"
                app:iconGravity="textStart"
                app:iconTint="@null"
                android:visibility="gone" />

            <!-- Gallery -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:text="Galeri Kegiatan"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/galleryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:weightSum="3">
                <!-- 3 ImageView diisi manual dari kode, sesuai maksimal 3 foto -->
                <ImageView
                    android:id="@+id/imgGallery1"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@color/divider"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/imgGallery2"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:background="@color/divider"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/imgGallery3"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@color/divider"
                    android:scaleType="centerCrop" />
            </LinearLayout>

            <!-- Member list -->
            <TextView
                android:id="@+id/tvMemberSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="6dp"
                android:text="Anggota"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
